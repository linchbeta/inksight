{
  "mode_id": "COUNTDOWN",
  "display_name": "Countdown",
  "icon": "flag",
  "cacheable": false,
  "description": "Days remaining until your target date",
  "settings_schema": [
    {
      "key": "countdownEvents",
      "label": "Countdown events"
    }
  ],
  "content": {
    "type": "computed",
    "provider": "countdown",
    "fallback": {
      "events": [
        {
          "name": "New Year",
          "date": "2027-01-01",
          "type": "countdown",
          "days": 100
        }
      ]
    },
    "fallback_pool": [
      {
        "events": [
          {
            "name": "New Year",
            "date": "2027-01-01",
            "type": "countdown",
            "days": 100
          }
        ]
      },
      {
        "events": [
          {
            "name": "Summer Vacation",
            "date": "2026-07-01",
            "type": "countdown",
            "days": 90
          }
        ]
      },
      {
        "events": [
          {
            "name": "Birthday",
            "date": "2026-06-15",
            "type": "countdown",
            "days": 110
          }
        ]
      },
      {
        "events": [
          {
            "name": "Project Deadline",
            "date": "2026-03-31",
            "type": "countdown",
            "days": 34
          }
        ]
      }
    ]
  },
  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body_align": "top",
    "body": [
      {
        "type": "spacer",
        "height": 18
      },
      {
        "type": "text",
        "field": "message",
        "font": "noto_serif_regular",
        "font_size": 16,
        "align": "center",
        "margin_x": 28,
        "max_lines": 2
      },
      {
        "type": "spacer",
        "height": 18
      },
      {
        "type": "list",
        "field": "events",
        "max_items": 1,
        "item_template": "{name}",
        "font_size": 14,
        "align": "center"
      },
      {
        "type": "list",
        "field": "events",
        "max_items": 1,
        "item_template": "{date}",
        "font_size": 11,
        "align": "center"
      },
      {
        "type": "separator",
        "style": "short",
        "width": 70
      },
      {
        "type": "spacer",
        "height": 18
      },
      {
        "type": "list",
        "field": "events",
        "max_items": 1,
        "item_template": "{days}",
        "font": "lora_bold",
        "font_size": 52,
        "item_spacing": 58,
        "align": "center"
      },
      {
        "type": "text",
        "template": "days to go",
        "font_name": "Lora-Regular.ttf",
        "font_size": 13,
        "align": "center",
        "max_lines": 1
      }
    ],
    "footer": {
      "label": "Countdown",
      "attribution_template": "— Remember"
    }
  },
  "layout_overrides": {
    "296x128": {
      "body_align": "center",
      "body": [
        {
          "type": "text",
          "field": "message",
          "font": "noto_serif_regular",
          "font_size": 16,
          "align": "center",
          "margin_x": 42,
          "max_lines": 2
        },
        {
          "type": "list",
          "field": "events",
          "max_items": 1,
          "item_template": "{name}",
          "font_size": 12,
          "align": "center"
        },
        {
          "type": "separator",
          "style": "short",
          "width": 40
        },
        {
          "type": "list",
          "field": "events",
          "max_items": 1,
          "item_template": "{days}",
          "font": "lora_bold",
          "font_size": 36,
          "item_spacing": 40,
          "align": "center"
        },
        {
          "type": "text",
          "template": "days to go",
          "font_name": "Lora-Regular.ttf",
          "font_size": 9,
          "align": "center"
        }
      ],
      "footer": {
        "label": "Countdown",
        "height": 18
      }
    },
    "800x480": {
      "body": [
        {
          "type": "spacer",
          "height": 22
        },
        {
          "type": "text",
          "field": "message",
          "font": "noto_serif_regular",
          "font_size": 16,
          "align": "center",
          "margin_x": 42,
          "max_lines": 2
        },
        {
          "type": "spacer",
          "height": 10
        },
        {
          "type": "list",
          "field": "events",
          "max_items": 1,
          "item_template": "{name}",
          "font_size": 20,
          "align": "center"
        },
        {
          "type": "list",
          "field": "events",
          "max_items": 1,
          "item_template": "{date}",
          "font_size": 16,
          "align": "center"
        },
        {
          "type": "separator",
          "style": "short",
          "width": 100
        },
        {
          "type": "spacer",
          "height": 28
        },
        {
          "type": "list",
          "field": "events",
          "max_items": 1,
          "item_template": "{days}",
          "font": "lora_bold",
          "font_size": 80,
          "item_spacing": 88,
          "align": "center"
        },
        {
          "type": "text",
          "template": "days to go",
          "font_name": "Lora-Regular.ttf",
          "font_size": 18,
          "align": "center",
          "max_lines": 1
        }
      ]
    }
  }
}
